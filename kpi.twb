      <aliases enabled='yes' />
      <column caption='Total Revenue' datatype='real' name='[Calculation_0050072174788609]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Sales])' />
      </column>
      <column caption='Avg Order Value' datatype='real' name='[Calculation_0050072175824898]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Sales]) / COUNTD([Order Id])' />
      </column>
      <column caption='Total Orders' datatype='integer' name='[Calculation_0050072176144387]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([Order Id])' />
      </column>
      <column caption='Total Profit' datatype='real' name='[Calculation_0050072176742404]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Order Item Profit Ratio])' />
      </column>
      <column caption='Profit Margin' datatype='real' name='[Calculation_0050072177553413]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Order Item Profit Ratio]) / SUM([Sales])' />
      </column>
      <column caption='Profit per Order' datatype='real' name='[Calculation_0050072177881094]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Order Item Profit Ratio]) / COUNTD([Order Id])' />
      </column>
      <column caption='Total Customers' datatype='integer' name='[Calculation_0050072178253831]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([Customer Id])' />
      </column>
      <column caption='Customer LTV' datatype='real' name='[Calculation_0050072178495496]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Customer Id] : SUM([Sales]) }' />
      </column>
      <column caption='Customer Type' datatype='string' name='[Calculation_0050072178745353]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF { FIXED [Customer Id] : COUNTD([Order Id]) } = 1 &#13;&#10;THEN &apos;New Customer&apos; &#13;&#10;ELSE &apos;Returning Customer&apos; &#13;&#10;END' />
      </column>
      <column caption='Delivery Days' datatype='integer' name='[Calculation_0050072179228682]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, [order date (DateOrders)], [shipping date (DateOrders)])' />
      </column>
      <column caption='On-Time Delivery' datatype='real' name='[Calculation_0050072179666955]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [Delivery Status] = &apos;Early&apos; OR [Delivery Status] = &apos;On Time&apos; &#13;&#10;THEN [Order Id] END) / COUNT([Order Id])' />
      </column>
      <column caption='Delivery Status1' datatype='string' name='[Calculation_0050072180031500]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF DATEDIFF(&apos;day&apos;, [order date (DateOrders)], [shipping date (DateOrders)]) &lt;= [Days for shipment (scheduled)] &#13;&#10;THEN &apos;On Time&apos; &#13;&#10;ELSE &apos;Late&apos; &#13;&#10;END' />
      </column>
      <column caption='Late Delivery Risk ' datatype='real' name='[Calculation_0050072180490253]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Late_delivery_risk]) / COUNT([Order Id])' />
      </column>
      <column caption='Product Sales Rank' datatype='integer' name='[Calculation_0050072180801550]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(SUM([Sales]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Category Sales' datatype='real' name='[Calculation_0050072181026831]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Sales]) / TOTAL(SUM([Sales]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Return Rate' datatype='real' name='[Calculation_0050072181354512]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [Order Status] = &apos;SUSPECTED_FRAUD&apos; OR [Order Status] = &apos;RETURNED&apos; &#13;&#10;THEN [Order Id] END) / COUNT([Order Id])' />
      </column>
      <column caption='Regional Profit Index' datatype='real' name='[Calculation_0050072181755921]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Order Item Profit Ratio]) / SUM([Sales])) * 100' />
      </column>
      <column caption='On-time Orders Count' datatype='integer' name='[Calculation_0050072277782546]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Late_delivery_risk] = 0 THEN 1 ELSE 0 END' />
      </column>
      <column caption='Order Fulfillment Rate (as percentage)' datatype='real' name='[Calculation_0050072278786067]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_0050072277782546]) / COUNT([Order Id]) * 100' />
      </column>
      <column caption='Late Delivery Rate' datatype='real' name='[Calculation_0050072279244820]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Late_delivery_risk]) / COUNT([Order Id])' />
      </column>
      <column caption='Is Perfect Order?' datatype='boolean' name='[Calculation_0050072280268822]' role='measure' type='nominal'>
        <calculation class='tableau' formula='SUM([Late_delivery_risk]) = 0&#13;&#10;AND ([Calculation_0050072177881094]) &gt; 0&#13;&#10;AND AVG([Order Item Discount Rate]) &lt; 0.2' />
      </column>
      <column caption='Total Cost' datatype='real' name='[Calculation_0050072288165915]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Sales]) - [Calculation_0050072176742404]' />
      </column>
      <column caption='Cost-to-Serve' datatype='real' name='[Calculation_0050072288952348]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Sales]) - [Calculation_0050072176742404]) / COUNT([Order Id])' />
      </column>
      <column caption='Total Quantity Sold' datatype='integer' name='[Calculation_0050072289255453]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Order Item Quantity])' />
      </column>
      <column caption='Order Cycle Time' datatype='integer' name='[Calculation_0050072289488926]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Days for shipping (real)]' />
      </column>
      <column caption='Revenue Per Order' datatype='real' name='[Calculation_0050072289857567]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Sales]) / COUNT([Order Id])' />
      </column>
      <column caption='Month-Year' datatype='datetime' name='[Calculation_0050072290959392]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;, [order date (DateOrders)])' />
      </column>
      <column caption='Order Fullfillment Rate' datatype='real' name='[Calculation_0050072291274785]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_0050072277782546])/ COUNT([Order Id])' />
      </column>
      <column caption='KPI Name' datatype='string' name='[Calculation_0050072292671522]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Order Fullfillment Rate&quot;' />
      </column>
      <column caption='KPI Name2' datatype='string' name='[Calculation_0050072292909091]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Late Delivery Rate&quot;' />
      </column>
      <column caption='KPI Name3' datatype='string' name='[Calculation_0050072293068836]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Average Shipping Delay&quot;' />
      </column>
      <column caption='KPI Name4' datatype='string' name='[Calculation_0050072293298213]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Perfect Order Rate&quot;' />
      </column>
      <column caption='KPI Name5' datatype='string' name='[Calculation_0050072293421094]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Profit Margin %&quot;' />
      </column>
      <column caption='KPI Name6' datatype='string' name='[Calculation_0050072293527591]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Cost-to-Serve&quot;' />
      </column>
      <column caption='KPI Name7' datatype='string' name='[Calculation_0050072293662760]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Inventory Turnover&quot;' />
      </column>
      <column caption='KPI Name8' datatype='string' name='[Calculation_0050072293781545]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Order Cycle Time&quot;' />
      </column>
