            </column>
            <column caption='OCT Value' datatype='real' name='[Calculation_0050072473669718]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG([Days for shipping (real)])' />
            </column>
            <column caption='Sps Label' datatype='string' name='[Calculation_0050072476659799]' role='dimension' type='nominal'>
