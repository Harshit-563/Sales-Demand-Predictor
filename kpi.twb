  <worksheets>
    <worksheet name='Sheet 1'>
      <table>
        <view>
          <datasources>
            <datasource caption='DataCoSupplyChain_clean' name='federated.0l6yu8d0df0prd1ahkl3y1q8itrr' />
          </datasources>
          <datasource-dependencies datasource='federated.0l6yu8d0df0prd1ahkl3y1q8itrr'>
            <column caption='Avg Order Value' datatype='real' name='[Calculation_0050072175824898]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Sales]) / COUNTD([Order Id])' />
            </column>
            <column caption='Total Orders' datatype='integer' name='[Calculation_0050072176144387]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD([Order Id])' />
            </column>
            <column caption='Total Profit' datatype='real' name='[Calculation_0050072176742404]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Order Item Profit Ratio])' />
            </column>
            <column caption='Profit Margin' datatype='real' name='[Calculation_0050072177553413]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Order Item Profit Ratio]) / SUM([Sales])' />
            </column>
            <column caption='On-time Orders Count' datatype='integer' name='[Calculation_0050072277782546]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Late_delivery_risk] = 0 THEN 1 ELSE 0 END' />
            </column>
            <column caption='Order Fulfillment Rate (as percentage)' datatype='real' name='[Calculation_0050072278786067]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Calculation_0050072277782546]) / COUNT([Order Id]) * 100' />
            </column>
            <column caption='Late Delivery Rate' datatype='real' name='[Calculation_0050072279244820]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Late_delivery_risk]) / COUNT([Order Id])' />
            </column>
            <column caption='Total Quantity Sold' datatype='integer' name='[Calculation_0050072289255453]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Order Item Quantity])' />
            </column>
            <column caption='Order Fullfillment Rate' datatype='real' name='[Calculation_0050072291274785]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Calculation_0050072277782546])/ COUNT([Order Id])' />
            </column>
            <column caption='OFR Label' datatype='string' name='[Calculation_0050072400105535]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='&quot;Order Fulfillment Rate&quot;' />
            </column>
            <column caption='OFR Value' datatype='real' name='[Calculation_0050072400506944]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Calculation_0050072278786067]' />
            </column>
            <column caption='OFR Symbol' datatype='string' name='[Calculation_0050072400707649]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='&quot; %&quot;' />
            </column>
            <column caption='LDR Label' datatype='string' name='[Calculation_0050072447230018]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='&quot;Late Delivery Rate&quot;' />
            </column>
            <column caption='LDR Value' datatype='string' name='[Calculation_0050072447549507]' role='measure' type='nominal'>
              <calculation class='tableau' formula='STR(ROUND([Calculation_0050072279244820] * 100, 2))' />
            </column>
            <column caption='LDR Symbol' datatype='string' name='[Calculation_0050072454561860]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='&quot; %&quot;' />
            </column>
            <column caption='AVD Label' datatype='string' name='[Calculation_0050072455213125]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='&quot;Avg Shipping Delay&quot;' />
            </column>
            <column caption='AVD Value' datatype='real' name='[Calculation_0050072455553094]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG(&#13;&#10;    [Days for shipping (real)]&#13;&#10;    - [Days for shipment (scheduled)]&#13;&#10;)' />
            </column>
            <column caption='AVD Symbol' datatype='string' name='[Calculation_0050072456818759]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='&quot; days&quot;' />
            </column>
            <column caption='POR Label' datatype='string' name='[Calculation_0050072457211976]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='&quot;Perfect Order Rate&quot;' />
            </column>
            <column caption='PM Label' datatype='string' name='[Calculation_0050072465510475]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='&quot;Profit Margin&quot;' />
            </column>
            <column caption='PM Value' datatype='real' name='[Calculation_0050072465813580]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM([Sales])/[Calculation_0050072176742404] + 100)/100' />
            </column>
            <column caption='PM Symbol' datatype='string' name='[Calculation_0050072468230221]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='&quot; %&quot;' />
            </column>
            <column caption='CTS Label' datatype='string' name='[Calculation_0050072469069902]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='&quot;Cost-to-Serve&quot;' />
            </column>
            <column caption='CTS Value' datatype='real' name='[Calculation_0050072469151823]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM([Sales])-[Calculation_0050072176742404])/ [Calculation_0050072176144387]' />
            </column>
            <column caption='CTS Symbol' datatype='string' name='[Calculation_0050072470376528]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='&quot;$&quot;' />
            </column>
            <column caption='IT Label' datatype='string' name='[Calculation_0050072470888529]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='&quot;Inventory Turnover&quot;' />
            </column>
            <column caption='IT Value' datatype='real' name='[Calculation_0050072470982738]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Calculation_0050072289255453]/[Calculation_0050072175824898]' />
            </column>
            <column caption='IT Symbol' datatype='string' name='[Calculation_0050072472711252]' role='dimension' type='nominal'>
